{
    "layer": "top",
    "position": "left",
    "width": 50,
    "exclusive": true,
    "passthrough": false,
    "spacing": 4,
    "modules-center": ["wlr/taskbar"],
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 28,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": ["Waybar"],
    },
}
